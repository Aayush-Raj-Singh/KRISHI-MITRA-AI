ENVIRONMENT=development
ENFORCE_SECURE_SECRETS=false
DATABASE_URL=postgresql://postgres:password@localhost:5432/krishi_db
POSTGRES_SCHEMA=public
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=5
DB_CONNECT_MAX_ATTEMPTS=3
DB_CONNECT_RETRY_DELAY_SECONDS=1.5
ALLOW_INMEMORY_DB_FALLBACK=false
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace-with-strong-access-secret-at-least-32-chars
JWT_REFRESH_SECRET_KEY=replace-with-strong-refresh-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=INFO
METRICS_ENABLED=true
METRICS_API_KEY=
CLIENT_ERROR_INGEST_ENABLED=true

CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,X-Request-Id

RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=12
RATE_LIMIT_ADVISORY_PER_MINUTE=30
RATE_LIMIT_UPLOAD_PER_MINUTE=12
RATE_LIMIT_EXPORT_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=60

PUBLIC_API_KEYS=
EXTERNAL_LINK_ALLOWLIST=

AWS_REGION=us-east-1
AWS_PROFILE=
AWS_SHARED_CREDENTIALS_FILE=
AWS_VALIDATION_MOCK_MODE=true
RUNTIME_VALIDATION_MOCK_MODE=false
AWS_VALIDATION_S3_BUCKET=
AWS_SECRETS_MANAGER_SECRET_ID=
LLM_PROVIDER=bedrock
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.7
BEDROCK_MODEL_ID=openai.gpt-oss-20b-1:0
BEDROCK_FALLBACK_MODEL_ID=openai.gpt-oss-120b-1:0
TRANSLATION_PROVIDER=aws
AWS_TRANSLATE_ENABLED=true
PUBLIC_TRANSLATE_FALLBACK_ENABLED=false
SAGEMAKER_RUNTIME_ENABLED=false
SAGEMAKER_CROP_ENDPOINT=
SAGEMAKER_PRICE_ENDPOINT=
WEATHER_API_URL=
WEATHER_API_KEY=
MANDI_API_URL=
MANDI_API_KEY=
MANDI_DEMO_API_KEY=
# For local/demo use, set MANDI_DEMO_API_KEY explicitly if your upstream requires a public demo key.
# Set a dedicated MANDI_API_KEY in staging/production to avoid rate limits and ensure stable daily refreshes.
EXTERNAL_HTTP_TIMEOUT_SECONDS=5.0
STATE_PORTAL_DIRECTORY_URL=https://farmerconnect.apeda.gov.in/Home/UsefulLinks
STATE_PORTAL_SNAPSHOT_STALE_HOURS=24
STATE_PORTAL_MAX_SOURCES_PER_STATE=4
STATE_PORTAL_SNAPSHOT_LINK_LIMIT=6
GEO_HIERARCHY_DISTRICT_CSV_URL=
GEO_HIERARCHY_BLOCK_CSV_URL=
GEO_HIERARCHY_VILLAGE_CSV_URL=
MODEL_ARTIFACTS_ROOT=model-artifacts
CROP_MODEL_ARTIFACT_PATH=
PRICE_HISTORY_PATH=
PRICE_ARTIFACT_DIR=
PRICE_METADATA_PATH=
DISEASE_LABELS_PATH=
DISEASE_MODEL_WEIGHTS_PATH=

OTP_PROVIDER=console
TWILIO_MOCK_MODE=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
